<resources>
    <!-- Base application theme. -->
    <style name="Theme.VerifyBlind" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
<item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_cyan</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorSecondaryVariant">@color/accent_orange</item>
        <item name="colorOnSecondary">@color/text_primary</item> 
        <!-- Transparent system bars: insets handled in code per-screen -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Window background (shown behind status/nav bar on all screens) -->
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    
    <style name="RoundedImageCorner" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>