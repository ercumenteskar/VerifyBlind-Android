<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Üst glow -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#002979FF"
                android:endColor="#302979FF" />
        </shape>
    </item>
    <!-- Ana çizgi -->
    <item android:top="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#002979FF"
                android:centerColor="#FF2979FF"
                android:endColor="#002979FF" />
        </shape>
    </item>
    <!-- Alt glow -->
    <item android:top="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#002979FF"
                android:endColor="#302979FF" />
        </shape>
    </item>
</layer-list>
