<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:background="@color/sv_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="#C4C6D0"
            android:backgroundTint="#C4C6D0"/>

        <!-- Logo -->
        <FrameLayout
            android:id="@+id/logoContainer"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_lock_icon_circle"
            android:clipToOutline="false">

            <ImageView
                android:id="@+id/ivPartnerLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvPartnerInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:visibility="visible"/>

        </FrameLayout>

        <!-- Partner Name -->
        <TextView
            android:id="@+id/tvPartnerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/sv_on_surface"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Kimlik bilgisi doğrulaması talep ediyor.\nTalep ettiği doğrulamaların gönderilmesini onaylıyor musunuz?"
            android:textColor="@color/sv_on_surface_variant"
            android:textSize="13sp"/>

        <!-- Section: PAYLAŞILACAK BİLGİLER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="PAYLAŞILACAK BİLGİLER"
            android:textColor="@color/sv_on_surface_variant"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"/>

        <!-- Dynamic scope items (added programmatically) -->
        <LinearLayout
            android:id="@+id/layoutScopeItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp"/>

        <!-- Kapsam footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Kapsam: Kimlik Doğrulama İsteği"
            android:textColor="@color/sv_on_surface_variant"
            android:textSize="13sp"/>

        <!-- KVKK Onay Checkbox -->
        <CheckBox
            android:id="@+id/cbKvkkConsent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Aydınlatma metnini okudum, kişisel verilerimin işlenmesini onaylıyorum."
            android:textColor="@color/sv_on_surface"
            android:textSize="13sp"
            android:buttonTint="@color/accent_blue"
            android:minHeight="48dp"/>

        <!-- Onayla Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApprove"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Onayla  →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_blue_gradient"
            app:backgroundTint="@null"
            app:cornerRadius="16dp"/>

        <!-- Reddet -->
        <TextView
            android:id="@+id/btnReject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="Reddet"
            android:textColor="@color/sv_on_surface_variant"
            android:textSize="15sp"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

    </LinearLayout>

</ScrollView>
