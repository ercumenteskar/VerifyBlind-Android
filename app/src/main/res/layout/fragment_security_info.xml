<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sv_background"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            app:tint="@color/sv_on_surface_variant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistem Güvenliği"
            android:textColor="@color/sv_on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp">

            <!-- Hardware Status Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:padding="24dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/ivShieldLarge"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/accent_blue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tvGuardStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DONANIM KORUMASI AKTİF"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivShieldLarge"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AWS Nitro Enclave Authorized"
                    android:textColor="@color/sv_on_surface_variant"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvGuardStatus"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GÜVENLİK DETAYLARI"
                android:textColor="@color/sv_on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- PCR0 Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/lblPcr0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enclave Parmak İzi (PCR0)"
                    android:textColor="@color/sv_on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tvPcr0Value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="7674350501a88504711eaaff3dc573c79001ac3cf7181b8831d30f6771dd8cc629658511cddea86d9423f68528611950"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/lblPcr0"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bu değer sunucuda çalışan kodun matematiksel özetidir. Kod değişirse bu özet de değişir."
                    android:textColor="@color/sv_on_surface_variant"
                    android:textSize="11sp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvPcr0Value"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Signer Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/lblSigner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yetkili Yayıncı"
                    android:textColor="@color/sv_on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tvSignerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="verifyblind.com"
                    android:textColor="@color/accent_blue"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lblSigner"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/accent_blue"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/tvSignerName"
                    app:layout_constraintTop_toTopOf="@id/tvSignerName"
                    app:layout_constraintBottom_toBottomOf="@id/tvSignerName"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sunucu kodu dijital olarak imzalanmış ve doğrulanmıştır."
                    android:textColor="@color/sv_on_surface_variant"
                    android:textSize="11sp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvSignerName"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Verification Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/lblVerify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Doğrulama Durumu"
                    android:textColor="@color/sv_on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tvVerifyStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Donanım Tarafından Onaylı"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lblVerify"/>

                <TextView
                    android:id="@+id/tvLastVerify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Son kontrol: Bugün, 18:20"
                    android:textColor="@color/sv_on_surface_variant"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvVerifyStatus"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- GitHub Source Link -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnViewSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivCode"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/sv_on_surface_variant"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kaynak Kodunu İncele"
                    android:textColor="@color/sv_on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/ivCode"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/sv_on_surface_variant"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VerifyBlind, işlem güvenliğini garantilemek için AWS Nitro Enclaves teknolojisini kullanan Zero-Trust mimarisine sahiptir."
                android:textColor="@color/sv_on_surface_variant"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingHorizontal="24dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
