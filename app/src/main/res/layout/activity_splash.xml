<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Outer leaking light (largest glow ring) -->
    <View
        android:id="@+id/viewGlowOuter"
        android:layout_width="420dp"
        android:layout_height="420dp"
        android:background="@drawable/bg_splash_glow_outer"
        app:layout_constraintTop_toTopOf="@id/ivSplashLogo"
        app:layout_constraintBottom_toBottomOf="@id/ivSplashLogo"
        app:layout_constraintStart_toStartOf="@id/ivSplashLogo"
        app:layout_constraintEnd_toEndOf="@id/ivSplashLogo" />

    <!-- Mid glow -->
    <View
        android:id="@+id/viewGlowMid"
        android:layout_width="270dp"
        android:layout_height="270dp"
        android:background="@drawable/bg_splash_glow_mid"
        app:layout_constraintTop_toTopOf="@id/ivSplashLogo"
        app:layout_constraintBottom_toBottomOf="@id/ivSplashLogo"
        app:layout_constraintStart_toStartOf="@id/ivSplashLogo"
        app:layout_constraintEnd_toEndOf="@id/ivSplashLogo" />

    <!-- Inner bright core glow -->
    <View
        android:id="@+id/viewGlowInner"
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:background="@drawable/bg_splash_glow_inner"
        app:layout_constraintTop_toTopOf="@id/ivSplashLogo"
        app:layout_constraintBottom_toBottomOf="@id/ivSplashLogo"
        app:layout_constraintStart_toStartOf="@id/ivSplashLogo"
        app:layout_constraintEnd_toEndOf="@id/ivSplashLogo" />

    <!-- Logo — slightly above center -->
    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintVertical_bias="0.40"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "VerifyBlind" title -->
    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VerifyBlind"
        android:textSize="34sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.04"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/ivSplashLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kimliğini Kanıtla, Gizliliğini Koru"
        android:textSize="14sp"
        android:textColor="#668596AD"
        android:letterSpacing="0.02"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
