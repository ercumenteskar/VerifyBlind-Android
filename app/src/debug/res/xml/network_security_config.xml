<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug base: cleartext kapalı (production ile aynı) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Lokal test sunucuları: HTTP'ye izin ver (fiziksel cihaz ve emülatör) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.113</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Debug: Charles Proxy / self-signed CA test sertifikalarına güven -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
